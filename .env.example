# ─── Frontend (exposé, anon key uniquement) ───────────────────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1...

# ─── Backend / Netlify Functions (secret, jamais dans le frontend) ─────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1...    ← Settings > API > service_role

# ─── TMDB (optionnel, pour les tendances + affiches HD) ───────────────────────
# Gratuit sur themoviedb.org → Settings > API > Create (API Read Access Token)
VITE_TMDB_KEY=your_tmdb_read_access_token
